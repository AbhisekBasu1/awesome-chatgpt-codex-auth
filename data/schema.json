{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "awesome-chatgpt-codex-auth projects",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "name",
      "slug",
      "category",
      "status",
      "auth",
      "subscription_auth_support",
      "description",
      "url",
      "docs",
      "notes",
      "last_verified"
    ],
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1
      },
      "slug": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "category": {
        "type": "string",
        "enum": [
          "official-platform",
          "editors-agents",
          "remote-control",
          "plugins-adapters",
          "proxies-api-shims"
        ]
      },
      "status": {
        "type": "string",
        "enum": [
          "official",
          "documented-third-party",
          "experimental-adapter",
          "experimental-proxy",
          "high-risk"
        ]
      },
      "auth": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1,
        "uniqueItems": true
      },
      "subscription_auth_support": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string",
        "minLength": 1
      },
      "url": {
        "type": "string",
        "format": "uri"
      },
      "docs": {
        "type": "array",
        "items": {
          "type": "string",
          "format": "uri"
        },
        "minItems": 1,
        "uniqueItems": true
      },
      "notes": {
        "type": "string",
        "minLength": 1
      },
      "last_verified": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    }
  }
}
